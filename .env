# Ollama Web Project - Environment Configuration
# Copy this file to .env and customize for your environment

# Server Configuration
HOST_PORT=8080
DOMAIN=dicabr.com.br

# Security (CHANGE IN PRODUCTION!)
API_KEY=ollama-web-secret-key-change-in-production
ENABLE_AUTH=false

# Performance Settings
MAX_CONCURRENT_JOBS=3
MAX_QUEUE_SIZE=100

# Ollama Configuration (REAL - No Simulation)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=runway/gen2-lite

# Storage Paths
VIDEO_DIR=/var/www/dicabr.com.br/data/videos
IMAGE_DIR=/var/www/dicabr.com.br/data/images
DATABASE_DIR=/var/www/dicabr.com.br/data/database

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
